# GitHub personal access token (required for org member sync)
GITHUB_TOKEN=ghp_your_token_here

# GitHub organization name
GITHUB_ORG=your-org

# Path to allowed_signers file
AUTHS_SIGNERS_PATH=.auths/allowed_signers

# Grafana admin password
GF_SECURITY_ADMIN_PASSWORD=admin

# SCIM webhook handler
SCIM_BEARER_TOKEN=your-scim-token-here
